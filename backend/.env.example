# =============================================================================
# jpeigo-slides — Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
#
# At least ONE translation provider is required.
# Gemini (free tier) and OpenCode are the recommended defaults.
# =============================================================================

# ---------------------------------------------------------------------------
# TRANSLATION PROVIDERS — at least one required
# ---------------------------------------------------------------------------

# Gemini (Google) — free tier available with 2.5 Flash Lite
# ⚠️  Free tier: set model to gemini-25-flash-lite. Newer 3.x models hit spending caps.
# Get a key at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# OpenCode — unified API for curated models (DeepSeek, Kimi, Qwen, MiniMax)
# Get a key at: https://opencode.ai
# OPENCODE_API_KEY=

# Google Cloud Translation API (traditional, reliable)
# GOOGLE_CLOUD_API_KEY=

# GLM-4 (BigModel / Zhipu)
# GLM_API_KEY=

# Kimi / Moonshot
# KIMI_API_KEY=

# MiniMax (also requires MINIMAX_GROUP_ID)
# MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=

# Qwen (DashScope / Alibaba Cloud)
# QWEN_API_KEY=

# Ollama — local models (no API key needed)
# OLLAMA_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# SERVER SETTINGS (optional)
# ---------------------------------------------------------------------------

# Allowed CORS origins (comma-separated if multiple)
# Default: http://localhost:3002
# CORS_ORIGINS=["http://localhost:3002","https://your-domain.com"]

# Default translation model (shown in UI)
# Options: gemini, opencode, auto
# DEFAULT_MODEL=gemini

# Enable debug logging
# DEBUG=false
